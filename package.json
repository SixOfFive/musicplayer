{
  "name": "musicplayer",
  "version": "0.1.0",
  "description": "Personal music player with a Spotify-style UI, local library scanning, metadata lookup, and Milkdrop-compatible visualizers.",
  "main": "dist-electron/electron/main.js",
  "author": "sixoffive",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "ffmpeg-static": "^5.2.0",
    "music-metadata": "^10.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "@electron/rebuild": "^3.7.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.sixoffive.musicplayer",
    "productName": "MusicPlayer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/ffmpeg*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/butterchurn-presets/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [ "dmg" ]
    },
    "linux": {
      "category": "AudioVideo;Audio;Player;",
      "target": [ "deb", "rpm", "tar.gz" ]
    },
    "win": {
      "target": [ { "target": "nsis", "arch": [ "x64" ] } ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MusicPlayer"
    }
  }
}
