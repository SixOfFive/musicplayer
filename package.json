{
  "name": "musicplayer",
  "version": "0.2.39",
  "description": "Personal music player with a Spotify-style UI, local library scanning, metadata lookup, and Milkdrop-compatible visualizers.",
  "main": "dist-electron/electron/main.js",
  "author": "sixoffive",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "release:patch": "npm version patch -m \"Release v%s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"Release v%s\" && git push && git push --tags",
    "release:major": "npm version major -m \"Release v%s\" && git push && git push --tags"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "chromecast-api": "^0.4.2",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "hls.js": "^1.6.16",
    "music-metadata": "^10.5.0",
    "node-ssdp": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "xml2js": "^0.4.23",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.sixoffive.musicplayer",
    "productName": "MusicPlayer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/ffmpeg*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/butterchurn-presets/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "category": "AudioVideo;Audio;Player;",
      "maintainer": "sixoffive <sixoffive@users.noreply.github.com>",
      "target": [
        "deb",
        "tar.gz"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SixOfFive",
        "repo": "musicplayer",
        "releaseType": "draft"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MusicPlayer",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "differentialPackage": false
    }
  }
}
